{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@cosmos-explorer/explorer#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "ADAPTER_TYPE",
        "CHAIN_ID",
        "CHAIN_NAME",
        "CHAIN_ENV",
        "BECH32_PREFIX",
        "PRIMARY_TOKEN_DENOM",
        "PRIMARY_TOKEN_DISPLAY_DENOM",
        "PRIMARY_TOKEN_EXPONENT",
        "GRAPHQL_HTTP",
        "GRAPHQL_WS",
        "EVM_EXPLORER",
        "PRICE_BASE_URL",
        "PRICE_ASSETS_BY_DENOM",
        "BRANDING_TITLE",
        "BRANDING_DESCRIPTION",
        "BRANDING_LOGO_PATH",
        "BRANDING_FAVICON",
        "LINKS_GITHUB",
        "LINKS_DISCORD",
        "LINKS_WEBSITE",
        "LINKS_ISSUES",
        "FEATURES_PROPOSALS",
        "FEATURES_ACCOUNTS",
        "FEATURES_EVM_SEARCH"
      ]
    },
    "lint": {},
    "@cosmos-explorer/juno#lint": {
      "dependsOn": ["@cosmos-explorer/callisto-app#lint"]
    },
    "typecheck": {},
    "test": {},
    "clean": {
      "cache": false
    }
  }
}
